    {
      "parameters": {
        "jsCode": "const text = $json.content;\n\n// split ONLY on === section markers (properly)\nconst sections = text.split(/===\\s*(.*?)\\s*===/g);\n\nconst templates = {};\n\n// sections will look like:\n// [\"\", \"new\", \"content...\", \"shortlisted\", \"content...\", ...]\nfor (let i = 1; i < sections.length; i += 2) {\n  const key = sections[i].toLowerCase().trim();\n  const content = sections[i + 1];\n\n  const lines = content\n    .split('\\n')\n    .map(l => l.trim())\n    .filter(Boolean);\n\n  const subjectLine = lines.find(l =>\n    l.toLowerCase().startsWith('subject:')\n  );\n\n  if (!subjectLine) continue;\n\n  const subject = subjectLine.split(':').slice(1).join(':').trim();\n\n  const body = lines\n    .slice(lines.indexOf(subjectLine) + 1)\n    .join('\\n');\n\n  templates[key] = { subject, body };\n}\n\nreturn [{ json: templates }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        176
      ],
      "id": "60a0247b-f37d-4ed6-9576-96160f22d844",
      "name": "Extract Templates"
    },
    {
      "parameters": {
        "functionCode": "const status =  $node[\"Google Sheets Trigger\"].json.Status.toLowerCase(); \n\nconst templates = $json;\nconst template = templates[status];\n\nif (!template) {\n  throw new Error(`No template found for status: ${status}`);\n}\n\nreturn [{\n  json: {\n    ...template,\n    candidate: $node[\"Google Sheets Trigger\"].json\n  }\n}];"
      },
      "id": "04307f7f-9825-4c3c-984e-f1494b3b5f26",
      "name": "Choose Template by Status",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        768,
        176
      ]
    },
    {
      "parameters": {
        "functionCode": "const { subject, body, candidate } = $json;\n\nconst map = {\n  \"{{Name}}\": candidate.Name,\n  \"{{Task_Link}}\": candidate[\"Task Link\"],\n  \"{{Email}}\": candidate.Email\n};\n\nlet finalSubject = subject;\nlet finalBody = body;\n\nfor (const key in map) {\n  finalSubject = finalSubject.replaceAll(key, map[key] || \"\");\n  finalBody = finalBody.replaceAll(key, map[key] || \"\");\n}\n\nreturn [{\n  json: {\n    email: candidate.Email,\n    subject: finalSubject,\n    body: finalBody\n  }\n}];"
      },
