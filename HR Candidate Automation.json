ions[i].trim().toLowerCase();\n  const lines = sections[i + 1].trim().split('\\n');\n  \n  const subjectLine = lines.find(l => \n    l.toLowerCase().startsWith('subject:')\n  );\n  \n  if (!subjectLine) continue;\n  \n  const subject = subjectLine.split(':').slice(1).join(':').trim();\n  const body = lines\n    .slice(lines.indexOf(subjectLine) + 1)\n    .join('\\n');\n  \n  templates[key] = { subject, body };\n}\n\nreturn [{ json: templates }];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[944,176],"id":"c99f098f-1bf1-40e2-b1f2-d5fdd1e63117","name":"Extract Templates"},{"parameters":{"functionCode":"// Input IS the templates object {new: {...}, shortlisted: {...}, completed: {...}}\nconst templates = $input.item.json;\n\n// Get candidate from Google Sheets Trigger\nconst candidate = $('Google Sheets Trigger').item.json;\n\n// Get status from candidate\nconst status = (candidate.Status || candidate.status || \"new\").toLowerCase();\n\n// Pick the right template\nconst template = templates[status];\n\nif (!template) {\n  throw new Error(`No template found for status: ${status}. Available: ${Object.keys(templates).join(', ')}`);\n}\n\nreturn {\n  subject: template.subject,\n  body: template.body,\n  candidate: candidate\n};"},"id":"8f8a9a3d-366c-4b49-b029-74383c02265e","name":"Choose Template by Status","type":"n8n-nodes-base.function","typeVersion":1,"position":[1152,176]},{"parameters":{"functionCode":"const { subject, body, candidate } = $json;\n\nconst map = {\n  \"{{Name}}\": candidate.Name,\n  \"{{Task_Link}}\": candidate[\"Task_Link\"],\n  \"{{Email}}\": candidate.Email,\n  \"{{Education}}\": candidate.Education,\n  \"{{Skills}}\": candidate.Skills\n};\n\nlet finalSubject = subject;\nlet finalBody = body;\n\nfor (const key in map) {\n  finalSubject = finalSubject.replaceAll(key, map[key] || \"\");\n  finalBody = finalBody.replaceAll(key, map[key] || \"\");\n}\n\nreturn [{\n  json: {\n    email: candidate.Email,\n    subject: finalSubject,\n    body: finalBody\n  }\n}];"},"id":"a843c8b1-ca42-4392-8438-68b691c2575b","name":"Personalize Email Content","type":"n8n-nodes-base.function","typeVersion":1,"position":[1360,176],"alwaysOutputData":true},{"parameters":{"conditions":{"string":[{"value1":"={{ $json.status_normalized }}","operation":"isEmpty"},{"value1":"={{ $json.status_normalized }}","value2":"new"}]},"combineOperation":"any"},"id":"41b77db7-30e9-42b0-9a34-3a7a27ea4aa3","name":"IF New","type":"n8n-nodes-base.if","typeVersion":1,"position":[384,0]},{"parameters":{"jsCode":"return [{\n  json: {\n    ...$json,\n    status_normalized: $json.Status?.toLowerCase().trim()\n  }\n}];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[80,192],"id":"8c1c8629-f889-4b2a-9a7b-6f5f3669fe99","name":"Normalized status","alwaysOutputData":true,"executeOnce":false},{"parameters":{"url":"https://docs.google.com/document/d/18-XYv5bZCErn5q3rvW8dKN6zmuOGDLw7I-87IZPi5Ho/export?format=txt","authentication":"predefinedCredentialType","nodeCredentialType":"googleDocsOAuth2Api","options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.4,"position":[752,176],"id":"141bcc0d-a5c6-4761-b773-bf0d740702ce","name":"HTTP Request","credentials":{"googleDocsOAuth2Api":{"id":"uvArUCfWQ1prquXb","name":"Google Docs account"}}}],"connections":{"IF Shortlisted":{"main":[[{"node":"HTTP Request","type":"main","index":0}]]},"IF Completed":{"main":[[{"node":"HTTP Request","type":"main","index":0}]]},"Send Email":{"main":[[{"node":"If","type":"main","index":0}]]},"If":{"main":[[{"node":"Update row in sheet","type":"main","index":0}],[{"node":"Update row in sheet1","type":"main","index":0}]]},"Extract Templates":{"main":[[{"node":"Choose Template by Status","type":"main","index":0}]]},"Choose Template by Status":{"main":[[{"node":"Personalize Email Content","type":"main","index":0}]]},"Personalize Email Content":{"main":[[{"node":"Send Email","type":"main","index":0}]]},"IF New":{"main":[[{"node":"HTTP Request","type":"main","index":0}]]