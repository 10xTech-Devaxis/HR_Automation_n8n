      "parameters": {
        "jsCode": "const row = $input.item.json;\nconst template = row.templates.new;\n\nconst subject = template.subject\n  .replace(/\\{\\{Name\\}\\}/g, row.Name);\n\nconst body = template.body\n  .replace(/\\{\\{Name\\}\\}/g, row.Name)\n  .replace(/\\{\\{Education\\}\\}/g, row.Education || 'your field')\n  .replace(/\\{\\{Task_Link\\}\\}/g, row.Task_Link);\n\nreturn [{ json: { to: row.Email, subject, body, name: row.Name }}];"
      },
